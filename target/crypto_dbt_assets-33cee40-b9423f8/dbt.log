{"data": {"conn_name": "model.crypto_data.fct_crypto_prices", "node_info": {"materialized": "table", "meta": {}, "node_checksum": "edf77ca6f3080cb1c7d41030e4cea88d7a52eb0b44c12d181457e4f684ead848", "node_finished_at": "", "node_name": "fct_crypto_prices", "node_path": "marts/fct_crypto_prices.sql", "node_relation": {"alias": "fct_crypto_prices", "database": "crypto_vault", "relation_name": "\"crypto_vault\".\"main\".\"fct_crypto_prices\"", "schema": "main"}, "node_started_at": "2026-03-02T18:49:31.515821", "node_status": "executing", "resource_type": "model", "unique_id": "model.crypto_data.fct_crypto_prices"}, "sql": "/* {\"app\": \"dbt\", \"dbt_version\": \"1.11.6\", \"profile_name\": \"crypto_data_profile\", \"target_name\": \"dev\", \"node_id\": \"model.crypto_data.fct_crypto_prices\"} */\n\n  \n    \n    \n\n    create  table\n      \"crypto_vault\".\"main\".\"fct_crypto_prices__dbt_tmp\"\n  \n    as (\n      \n\nWITH prices AS (\n    SELECT * FROM \"crypto_vault\".\"main\".\"stg_raw_coin_data\"\n)\n\nselect\n    ticker,\n    price_eur,\n    processed_at,\n    -- Data Quality Flag: flag if the price is valid (positive)\n    case when price_eur > 0 then true else false end as is_valid_price\nfrom prices\n    );\n  \n  "}, "info": {"category": "", "code": "E016", "extra": {}, "invocation_id": "d0773230-5ec6-48ba-9da1-18da099c487a", "level": "debug", "msg": "On model.crypto_data.fct_crypto_prices: /* {\"app\": \"dbt\", \"dbt_version\": \"1.11.6\", \"profile_name\": \"crypto_data_profile\", \"target_name\": \"dev\", \"node_id\": \"model.crypto_data.fct_crypto_prices\"} */\n\n  \n    \n    \n\n    create  table\n      \"crypto_vault\".\"main\".\"fct_crypto_prices__dbt_tmp\"\n  \n    as (\n      \n\nWITH prices AS (\n    SELECT * FROM \"crypto_vault\".\"main\".\"stg_raw_coin_data\"\n)\n\nselect\n    ticker,\n    price_eur,\n    processed_at,\n    -- Data Quality Flag: flag if the price is valid (positive)\n    case when price_eur > 0 then true else false end as is_valid_price\nfrom prices\n    );\n  \n  ", "name": "SQLQuery", "pid": 37634, "thread": "Thread-1 (worker)", "ts": "2026-03-02T18:49:31.532734Z"}}
